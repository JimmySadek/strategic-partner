#!/usr/bin/env bash
set -euo pipefail

# ── Native Windows fail-loud detection ──────────────────────────────────
# Per OS-compatibility audit (2026-04-22) decision D: SP is WSL-first on
# Windows. Native Git Bash / MSYS2 / Cygwin can silently downgrade ln -s
# to file copies, breaking the readlink -f-based install-dir resolution.
# Require explicit opt-in to avoid silent-failure cascades.
case "${OSTYPE:-}" in
    msys*|cygwin*|MINGW*)
        if [ "${SP_ALLOW_NATIVE_WINDOWS:-}" != "1" ]; then
            cat >&2 <<'NATIVE_WARN'
⚠️  Native Windows (Git Bash / MSYS / Cygwin) is experimental / best-effort for Strategic Partner.

Known issues on native Windows Git Bash:
  • `setup` may create file copies instead of symlinks (breaks command updates)
  • Self-repair and version-check may return wrong paths
  • Some features require Python 3 alias configuration

Recommended: use WSL2 for full compatibility.

To proceed anyway (experimental, at your own risk):
    SP_ALLOW_NATIVE_WINDOWS=1 bash setup

See .handoffs/os-compatibility-audit-0422.md (if repo cloned) for full
finding details, or https://github.com/JimmySadek/strategic-partner for docs.
NATIVE_WARN
            exit 2
        fi
        echo "ℹ️  Proceeding on native Windows Git Bash (experimental mode, SP_ALLOW_NATIVE_WINDOWS=1)."
        ;;
esac

# setup — Register strategic-partner subcommands with Claude Code
# Idempotent. Safe to re-run. Called by install + /strategic-partner:update.

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Delegate to audit-permissions if requested ─────────────────────────
_find_python3() {
    if command -v python3 >/dev/null 2>&1; then
        echo "python3"
        return 0
    fi
    if command -v python >/dev/null 2>&1 && python -c 'import sys; sys.exit(0 if sys.version_info[0]==3 else 1)' 2>/dev/null; then
        echo "python"
        return 0
    fi
    if command -v py >/dev/null 2>&1 && py -3 -c 'pass' 2>/dev/null; then
        echo "py -3"
        return 0
    fi
    return 1
}

if [ "${1:-}" = "--audit-permissions" ]; then
  shift
  PYTHON_CMD=$(_find_python3) || {
      echo "❌ audit-permissions requires Python 3. Install from python.org or your package manager, then retry." >&2
      exit 1
  }
  exec $PYTHON_CMD "${SKILL_DIR}/audit-permissions" "$@"
fi

COMMANDS_SRC="${SKILL_DIR}/commands"
COMMANDS_DST="${HOME}/.claude/commands/strategic-partner"

# ── Legacy cleanup warning ──────────────────────────────────────────────
LEGACY_DIR="${HOME}/.claude/skills/strategic-partner"
if [ -d "$LEGACY_DIR" ] && [ ! -L "$LEGACY_DIR" ]; then
  echo "⚠️  Stale legacy installation detected: ${LEGACY_DIR}"
  echo "   This is a leftover copy, not a symlink. You can safely remove it:"
  echo "   rm -rf ${LEGACY_DIR}"
  echo ""
fi

# ── Register subcommands ────────────────────────────────────────────────
if [ ! -d "$COMMANDS_SRC" ]; then
  echo "⚠️  No commands/ directory found in ${SKILL_DIR}. Skipping command registration."
  exit 0
fi

mkdir -p "$COMMANDS_DST"

linked=0
for cmd in "${COMMANDS_SRC}"/*.md; do
  [ -f "$cmd" ] || continue
  filename="$(basename "$cmd")"
  ln -snf "$cmd" "${COMMANDS_DST}/${filename}"
  linked=$((linked + 1))
done

if [ "$linked" -gt 0 ]; then
  echo "✅ Registered ${linked} subcommand(s) in ${COMMANDS_DST}"
else
  echo "✅ No command files found to register."
fi

# ── Ensure hook scripts are executable ─────────────────────────────────
HOOKS_DIR="${SKILL_DIR}/hooks"
if [ -d "$HOOKS_DIR" ]; then
  chmod +x "${HOOKS_DIR}"/*.sh 2>/dev/null || true
  echo "✅ Hook scripts verified executable in ${HOOKS_DIR}"
fi

# ── Quick permission check ─────────────────────────────────────────────
SETTINGS_FILE="${HOME}/.claude/settings.json"
if [ -f "$SETTINGS_FILE" ]; then
  missing=""
  grep -q "mcp__plugin_serena_serena__" "$SETTINGS_FILE" || missing="serena"
  grep -q "mcp__plugin_context7_context7__" "$SETTINGS_FILE" || missing="${missing:+$missing }context7"
  if [ -n "$missing" ]; then
    echo "💡 Missing SP permissions. Run: bash ${SKILL_DIR}/setup --audit-permissions"
  fi
fi
